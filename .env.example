#
# Скопируйте этот файл в ".env" и заполните значения.
# ВНИМАНИЕ: не коммитьте ".env" — он должен быть только локально.
#

# Telegram
BOT_TOKEN=your_telegram_bot_token

# Bot mode
# polling - по умолчанию
# webhook - используйте на сервере (нужен публичный WEBHOOK_URL)
BOT_RUN_MODE=polling
WEBHOOK_URL=

# Database (рекомендуется)
# Для локальной разработки проще всего SQLite:
DATABASE_URL=sqlite:///./consultation_bot.sqlite3

# PostgreSQL (если не используете DATABASE_URL)
DB_USER=postgres
DB_PASS=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=consultation_bot

# Optional: запускать встроенный web-сервер приложения (не Telegram webhook)
ENABLE_WEB_SERVER=false

# Web server (для webhook режима и/или внутренних эндпоинтов)
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_TIMEOUT=60
WEB_MAX_CONNECTIONS=100

# URL вашего внутреннего/внешнего web-сервиса (если используется)
WEB_SERVICE_HOST=localhost
WEB_SERVICE_PORT=8000

# Webhook path
WEB_WEBHOOK_PATH=/webhook

# Админы (ID через запятую)
ADMIN_IDS=123456789

# Ограничения/настройки записи
BOOKING_LIMIT=3

# Валюта
CURRENCY=RUB
CURRENCY_SYMBOL=₽

# Баланс: максимум пополнения
MAX_DEPOSIT_AMOUNT=1000000

# ЮKassa
YOOKASSA_SHOP_ID=YOUR_SHOP_ID
YOOKASSA_SECRET_KEY=YOUR_SECRET_KEY
YOOKASSA_RETURN_URL=https://your-site.example/return

# Базовая цена консультации
CONSULTATION_PRICE=1500
